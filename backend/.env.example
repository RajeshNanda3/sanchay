# ===================================
# SMS OTP Configuration
# ===================================
# Choose ONE provider: 2factor, msg91, aws, or twilio
OTP_PROVIDER=2factor

# 2Factor.in API Configuration (SMS-ONLY by default)
OTP_API_KEY=your_2factor_api_key_here

# MSG91 Configuration (Alternative - SMS-ONLY)
# SMS-ONLY: Uses 'otp' route which does NOT fallback to voice
# MSG91_API_KEY=your_msg91_api_key
# MSG91_DLT_TE_ID=your_dlt_te_id  # Optional: if your region requires DLT
# MSG91_TEMPLATE_ID=your_template_id  # Optional: if using approved DLT template

# AWS SNS Configuration (Alternative - SMS-ONLY)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Twilio Configuration (Alternative - SMS-ONLY by default)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ===================================
# Email Configuration (Optional - if still using email)
# ===================================
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password

# ===================================
# Database Configuration
# ===================================
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ===================================
# Redis Configuration
# ===================================
REDIS_URL=redis://localhost:6379

# ===================================
# JWT & Security
# ===================================
JWT_SECRET=your_jwt_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
CSRF_SECRET=your_csrf_secret_here

# ===================================
# Cloudinary Configuration
# ===================================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===================================
# Server Configuration
# ===================================
PORT=5000
NODE_ENV=development
